generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  scheduled
  locked
  in_progress
  played
  canceled
}

enum PitchType {
  F5
  F7
  F8
  F11
}

enum Role {
  USER
  ADMIN
}

enum UserGender {
  MALE
  FEMALE
  OTHER
}

enum PreferredPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum SkillLevel {
  BEGINNER
  AMATEUR
  REGULAR
  SEMIPRO
  PRO
}

model User {
  id               String             @id @default(uuid()) @db.Uuid
  email            String             @unique
  username         String             @unique
  passwordHash     String
  role              Role               @default(USER)
  gender            UserGender?
  firstName         String?
  lastName          String?
  birthDate         DateTime?          @db.Date
  preferredPosition PreferredPosition?
  skillLevel        SkillLevel?
  termsAcceptedAt   DateTime           @default(now())
  lateLeaveCount             Int                @default(0)
  reliabilityScore           Int                @default(100) @db.SmallInt
  reliabilityWindowStartedAt DateTime?
  suspendedUntil             DateTime?
  bannedAt                   DateTime?
  banReason                  String?
  emailVerifiedAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  matches          Match[]
  participations   MatchParticipant[]
  teamSlots        MatchTeamSlot[]
  ownedGroups      Group[]            @relation("GroupOwner")
  groupMemberships GroupMember[]
  auditLogs        MatchAuditLog[]    @relation("UserAuditLogs")
  avatar           UserAvatar?
  sentMessages       Message[]
  directConvsAsA     Conversation[]         @relation("ConversationUserA")
  directConvsAsB     Conversation[]         @relation("ConversationUserB")
  conversationReads  ConversationReadState[]
  pushDevices        PushDevice[]
  authSessions        AuthSession[]
  emailTokens         EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

model UserAvatar {
  userId      String   @id @db.Uuid
  key         String
  contentType String
  size        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Venue {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  addressText String?
  mapsUrl     String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  pitches     VenuePitch[]
  matches     Match[]

  @@index([isActive])
}

model VenuePitch {
  id        String     @id @default(uuid()) @db.Uuid
  venueId   String     @db.Uuid
  name      String
  pitchType PitchType
  price     Float?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  venue     Venue      @relation(fields: [venueId], references: [id])
  matches   Match[]

  @@index([pitchType, isActive])
  @@index([venueId])
}

model Match {
  id              String             @id @default(uuid()) @db.Uuid
  title           String
  startsAt        DateTime
  location        String?
  capacity        Int
  status          MatchStatus        @default(scheduled)
  revision        Int                @default(1)
  isLocked        Boolean            @default(false)
  lockedAt        DateTime?
  lockedBy        String?            @db.Uuid
  createdById     String             @db.Uuid
  venueId         String?            @db.Uuid
  venuePitchId    String?            @db.Uuid
  venueSnapshot   Json?
  pitchSnapshot   Json?
  teamsConfigured     Boolean            @default(false)
  teamsAutoGenBlocked Boolean            @default(false)
  createdBy    User               @relation(fields: [createdById], references: [id])
  venue        Venue?             @relation(fields: [venueId], references: [id])
  venuePitch   VenuePitch?        @relation(fields: [venuePitchId], references: [id])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  participants MatchParticipant[]
  auditLogs    MatchAuditLog[]
  teamSlots    MatchTeamSlot[]
  conversation Conversation?

  @@index([createdById], map: "Match_createdById_idx")
  @@index([startsAt], map: "Match_startsAt_idx")
}

model MatchTeamSlot {
  id        String  @id @default(uuid()) @db.Uuid
  matchId   String  @db.Uuid
  team      String
  slotIndex Int
  userId    String? @db.Uuid

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([matchId, team, slotIndex])
  @@index([matchId, team])
}

enum MatchParticipantStatus {
  INVITED
  CONFIRMED
  WAITLISTED
  SPECTATOR
}

model MatchParticipant {
  id               String                 @id @default(uuid()) @db.Uuid
  matchId          String                 @db.Uuid
  userId           String                 @db.Uuid
  status           MatchParticipantStatus
  waitlistPosition Int?
  confirmedAt      DateTime?
  isMatchAdmin     Boolean                @default(false)
  adminGrantedAt   DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([matchId, userId], map: "MatchParticipant_matchId_userId_key")
  @@index([matchId, status], map: "MatchParticipant_matchId_status_idx")
  @@index([matchId, waitlistPosition], map: "MatchParticipant_matchId_waitlistPosition_idx")
  @@index([matchId, createdAt], map: "MatchParticipant_matchId_createdAt_idx")
  @@index([userId, matchId], map: "MatchParticipant_userId_matchId_idx")
}

model Group {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  ownerId      String        @db.Uuid
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members      GroupMember[]
  conversation Conversation?

  @@index([ownerId])
}

model GroupMember {
  groupId   String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@index([userId])
}

model MatchAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @db.Uuid
  actorId   String?  @db.Uuid
  type      String
  metadata  Json
  createdAt DateTime @default(now())

  match Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  actor User?  @relation("UserAuditLogs", fields: [actorId], references: [id])

  @@index([matchId, createdAt(sort: Desc)])
}

model PushDevice {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  expoPushToken String    @unique
  platform      String
  deviceName    String?
  deviceId      String?
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  disabledAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([deviceId])
}

model NotificationDelivery {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  matchId   String?  @db.Uuid
  groupId   String?  @db.Uuid
  type      String
  bucket    String?
  createdAt DateTime @default(now())

  @@index([userId, matchId, type, createdAt])
  @@index([userId, groupId, type, createdAt])
  @@index([userId, matchId, type, bucket])
}

model IdempotencyRecord {
  id           String   @id @default(uuid()) @db.Uuid
  key          String
  actorId      String   @db.Uuid
  route        String
  matchId      String?  @db.Uuid
  requestHash  String
  statusCode   Int      @default(200)
  responseJson Json
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([key, actorId, route], map: "IdempotencyRecord_key_actorId_route_key")
  @@index([expiresAt], map: "IdempotencyRecord_expiresAt_idx")
}

model AuthSession {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  refreshTokenHash    String
  createdAt           DateTime  @default(now())
  lastUsedAt          DateTime  @default(now())
  expiresAt           DateTime
  revokedAt           DateTime?
  deviceId            String?
  deviceName          String?
  platform            String?
  appVersion          String?
  ip                  String?
  userAgent           String?
  replacedBySessionId String?   @db.Uuid
  user                User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  tokenHash        String
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  usedAt           DateTime?
  requestIp        String?
  requestUserAgent String?
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

// ── Chat ──────────────────────────────────────────────────────────────────────

model Conversation {
  id        String    @id @default(uuid()) @db.Uuid
  type      String    // 'MATCH' | 'GROUP' | 'DIRECT'
  matchId   String?   @unique @db.Uuid
  groupId   String?   @unique @db.Uuid
  userAId   String?   @db.Uuid  // DIRECT only — lexicographically smaller userId
  userBId   String?   @db.Uuid  // DIRECT only — lexicographically larger userId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  match      Match?                   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group      Group?                   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userA      User?                    @relation("ConversationUserA", fields: [userAId], references: [id])
  userB      User?                    @relation("ConversationUserB", fields: [userBId], references: [id])
  messages   Message[]
  readStates ConversationReadState[]

  @@unique([userAId, userBId])
  @@index([type])
}

// Tracks when each user last read each conversation — used for hasUnread and push suppression.
model ConversationReadState {
  userId         String   @db.Uuid
  conversationId String   @db.Uuid
  lastReadAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
  @@index([conversationId])
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  senderId       String   @db.Uuid
  body           String
  clientMsgId    String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
  createdAt    DateTime     @default(now())

  @@unique([conversationId, senderId, clientMsgId])
  @@index([conversationId, createdAt(sort: Desc)])
}

model AuthAuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  eventType String
  sessionId String?  @db.Uuid
  ip        String?
  userAgent String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
}
